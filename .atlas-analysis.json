  "keyFeatures": [
    "Full LoRaWAN 1.0.x and 1.1 support (Class A, B, C devices)",
    "Integrated Network Server, Application Server, Join Server, and Gateway Server",
    "OAuth 2.0 Identity Server with user, organization, and API key management",
    "MQTT and HTTP Webhook application integrations",
    "Command-line interface (ttn-lw-cli) for full stack management",
    "Web Console for visual management of devices, gateways, and applications",
    "Adaptive Data Rate and MAC command support",
    "Packet Broker integration for network peering",
    "Docker-based deployment with Redis and PostgreSQL",
    "JavaScript SDK for programmatic stack access"
  ],
  "publicApiSurface": [
    "ApplicationRegistry (CRUD for applications)",
    "EndDeviceRegistry (CRUD for end devices)",
    "GatewayRegistry (CRUD for gateways)",
    "UserRegistry (CRUD for users)",
    "DownlinkQueue (Push/Replace downlink messages)",
    "ApplicationPubSub (pub/sub integrations)",
    "ApplicationWebhooks (HTTP webhook integrations)",
    "ApplicationServer MQTT API",
    "JoinServer (OTAA session key derivation)",
    "NetworkServer MAC settings profiles",
    "ttn-lw-cli commands: applications, end-devices, gateways, users, organizations",
    "gRPC APIs for all server components",
    "HTTP REST APIs (via gRPC-gateway)",
    "JavaScript SDK (sdk/js)"
  ]
